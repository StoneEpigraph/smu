{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SMU",
  "version": "1.0.0",
  "identifier": "cn.stonemind.smu",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3535",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SMU",
        "width": 800,
        "height": 600,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": []
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:krunner.db"]
    }
  }
}