{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SMU",
  "version": "0.1.0",
  "identifier": "cn.stonemind.smu",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3535",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SMU",
        "width": 900,
        "height": 750,
        "minWidth": 900,
        "minHeight": 750,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "targets": [],
    "linux": {
      "deb": {
        "desktopTemplate": ""
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:krunner.db"]
    }
  }
}